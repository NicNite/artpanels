# ArtPanels FLUX Server Configuration
# Copy to .env and adjust as needed

# HuggingFace token (optional, for private model repos)
HF_TOKEN=

# Model to use (default: FLUX.1 Schnell)
MODEL_ID=black-forest-labs/FLUX.1-schnell

# Device: cuda, mps, or cpu (auto-detected if empty)
DEVICE=

# Default image size in pixels
IMAGE_SIZE=512

# Mock mode: true for development without GPU
MOCK=false
